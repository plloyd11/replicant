---
let { shows } = Astro.props;
import { Image } from 'astro:assets';

// sort by raw date (oldest first) before formatting
shows.sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

// format date for display
shows = shows.map((show) => {
    const date = new Date(show.date);
    const month = date.toLocaleString('default', { month: 'long' });
    const day = date.getDate();
    const year = date.getFullYear();
    const formattedDate = `${month} ${day}, ${year}`;
    return {
        ...show,
        date: formattedDate,
    };
});
---

<div class="grid gap-12 sm:grid-cols-2">
    {
        shows.map((show) => (
            <div class="col-span-1 text-replicant-200 h-full">
                <Image
                    src={show.flyer.url}
                    alt={show.title}
                    width={592}
                    height={740}
                    format="avif"
                />
                <div class="mt-4 space-y-2">
                    <div class="mt-4 space-x-2 flex justify-between flex-col sm:flex-row">
                        <span class="inline-block text-lg">{show.date}</span>
                        <div class="flex gap-2">
                            <a
                                href={show.tickets}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-block text-lg underline text-primary hover:text-primary-dark"
                            >
                                Tickets
                            </a>
                            <span class="inline-block">•</span>
                            <a
                                href={`https://www.google.com/maps/search/?api=1&query=${show.venue.latitude},${show.venue.longitude}`}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-block text-lg underline text-primary hover:text-primary-dark"
                            >
                                Directions to {show.venueName}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        ))
    }
</div>
